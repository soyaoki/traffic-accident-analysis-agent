# API キーをコピーして .env として保存してください
# cp .env.example .env

# OpenAI
OPENAI_API_KEY=sk-...

# Google Gemini (AI Studio: https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIza...

# 使用するモデル（デフォルト: gpt-4o-mini）
# OpenAI:  gpt-4o-mini / gpt-4o
# Gemini:  gemini-2.5-flash / gemini-2.0-flash
AGENT_MODEL=gpt-4o-mini
