# API キーをコピーして .env として保存してください
# cp .env.example .env

# ---- OpenAI ----
OPENAI_API_KEY=sk-...

# 使用するモデル（デフォルト: gpt-5.5）
# 使用可能なモデル名は以下を参照：
# OpenAI: https://platform.openai.com/docs/models
AGENT_MODEL=gpt-5.5

# ----- Google -----
# Vertex AI 設定 (有料枠を使用する場合のみ必要)
VERTEX_PROJECT_ID=your-project-id
VERTEX_REGION=us-central1

# Gemini (AI Studio: https://aistudio.google.com/apikey)
# API Studio の場合は API キー、Vertex AI の場合はアクセストークンを入力
GEMINI_API_KEY=AIza...

# 検索に使用する Gemini モデル (Google Search Grounding 用)
# AGENT_MODEL に OpenAI モデルを指定した場合でも、検索機能はこのモデル（Gemini）が使用されます
# 使用可能なモデル名は以下を参照：
# Gemini: https://ai.google.dev/gemini-api/docs/models?hl=ja
SEARCH_MODEL=gemini-3.1-pro-preview
