# API キーをコピーして .env として保存してください
# cp .env.example .env

# OpenAI
OPENAI_API_KEY=sk-...

# Google Gemini (AI Studio: https://aistudio.google.com/apikey)
# API Studio の場合は API キー、Vertex AI の場合はアクセストークンを入力
GEMINI_API_KEY=AIza...

# Vertex AI 設定 (有料枠を使用する場合のみ必要)
VERTEX_PROJECT_ID=your-project-id
VERTEX_REGION=us-central1

# 使用するモデル（デフォルト: gpt-4o-mini）
# OpenAI:  gpt-4o-mini / gpt-4o
# Gemini (AI Studio): gemini-2.5-flash
# Gemini (Vertex AI): google/gemini-1.5-flash
AGENT_MODEL=gemini-2.5-flash
